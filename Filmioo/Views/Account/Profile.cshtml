@model UserViewModel
<!DOCTYPE html>

<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>User Profile</title>
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&amp;family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="~/css/actors.css" rel="stylesheet" asp-append-version="true" />


    <script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              "colors": {
                      "on-secondary": "#1d0033",
                      "surface": "#0a0a0c",
                      "inverse-surface": "#e5e1e6",
                      "on-primary-fixed": "#21005d",
                      "tertiary-container": "#004e5d",
                      "secondary-fixed-dim": "#d0bcff",
                      "on-surface-variant": "#c9c4d0",
                      "tertiary": "#80d4e6",
                      "primary-fixed": "#eaddff",
                      "background": "#0a0a0c",
                      "on-background": "#e5e1e6",
                      "primary": "#d0bcff",
                      "primary-fixed-dim": "#d0bcff",
                      "secondary-fixed": "#eaddff",
                      "surface-container-high": "#25232a",
                      "secondary-container": "#4f378b",
                      "surface-variant": "#49454f",
                      "surface-bright": "#3b383e",
                      "inverse-primary": "#6750a4",
                      "on-surface": "#e5e1e6",
                      "on-secondary-fixed-variant": "#4f378b",
                      "on-error": "#601410",
                      "surface-container-highest": "#36343b",
                      "surface-tint": "#d0bcff",
                      "on-primary-fixed-variant": "#4f378b",
                      "on-tertiary": "#00363f",
                      "error": "#f2b8b5",
                      "outline": "#938f99",
                      "surface-container": "#1d1b20",
                      "inverse-on-surface": "#313033",
                      "tertiary-fixed": "#afeefd",
                      "surface-dim": "#0a0a0c",
                      "on-tertiary-container": "#afeefd",
                      "on-primary-container": "#eaddff",
                      "tertiary-fixed-dim": "#80d4e6",
                      "surface-container-low": "#131216",
                      "secondary": "#d0bcff",
                      "on-secondary-fixed": "#21005d",
                      "on-primary": "#381e72",
                      "on-secondary-container": "#eaddff",
                      "primary-container": "#6b46c1",
                      "on-tertiary-fixed-variant": "#004e5d",
                      "on-tertiary-fixed": "#001f24",
                      "surface-container-lowest": "#050505",
                      "outline-variant": "#49454f",
                      "on-error-container": "#f9dedc",
                      "error-container": "#8c1d18"
              },
              "borderRadius": {
                      "DEFAULT": "0.125rem",
                      "lg": "0.5rem",
                      "xl": "1rem",
                      "full": "9999px"
              },
              "fontFamily": {
                      "headline": ["Manrope"],
                      "body": ["Inter"],
                      "label": ["Inter"]
              }
            },
          },
        }
    </script>
    <style>
        :root {
            --filmioo-black: #121212; 
            --filmioo-purple-main: #9333ea; 
            --filmioo-purple-light: #c084fc; 
            --filmioo-text-color: #f0f0f0; 
        }

        body {
            background-color: #0b0b0f;
            color: #ffffff;
            font-family: 'Segoe UI', sans-serif;
        }

        .navbar {
            background-color: #000;
            box-shadow: 0 0 15px rgba(138,43,226,.5);
        }

        .navbar-brand {
            color: #b45cff !important;
            font-weight: 800;
            font-size: 1.6rem;
        }


        
        .btn-purple {
            background-color: #8a2be2;
            color: #fff;
            border-radius: 30px;
            padding: 10px 25px;
            transition: .3s;
        }
        .filmioo-navbar {
            background-color: rgba(0, 0, 0, 0.9); 
            border-bottom: 3px solid var(--filmioo-purple-main);
        }

        .filmioo-logo {
            color: var(--filmioo-purple-main) !important;
            font-size: 1.6rem;
            font-weight: 700;
            text-shadow: 0 0 8px var(--filmioo-purple-light);
        }

        .filmioo-nav-link,
        .filmioo-icon {
            color: var(--filmioo-text-color) !important;
            font-size: 1rem;
            font-weight: 500;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
        }

            .filmioo-nav-link:hover,
            .filmioo-icon:hover {
                color: var(--filmioo-purple-light) !important;
                text-shadow: 0 0 8px var(--filmioo-purple-light);
                transform: translateY(-2px);
            }

        .nav-auth-link {
            font-weight: 600; 
            opacity: 0.9;
        }


        .btn-purple:hover {
            background-color: #a855f7;
            box-shadow: 0 0 15px #8a2be2;
        }

       


        h1, h2, h3 {
            font-family: 'Manrope', sans-serif;
        }

        .glass-panel {
            background: rgba(45, 43, 52, 0.4);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .glass-card {
            background: rgba(30, 28, 35, 0.6);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        

    </style>
</head>
<body >
    <nav class="navbar navbar-expand-lg filmioo-navbar sticky-top !bg-black !border-b-2 !border-purple-600 !py-2">
        <div class="container-fluid !flex !flex-row !flex-nowrap !items-center !justify-between px-6">

            <a class="navbar-brand filmioo-logo !flex !items-center !mr-8" asp-action="Index" asp-controller="Home">
                Filmioo
            </a>

            <div class="!flex !flex-row !items-center !justify-between w-full" id="navbarNav">

                <div class="flex flex-row items-center gap-8">
                    <a class="!flex items-center gap-2 no-underline text-white hover:text-purple-400 transition-all" asp-action="Index" asp-controller="Actor">
                        <i class="bi bi-people text-purple-400 text-xl"></i>
                        <span class="font-medium">Actors</span>
                    </a>

                    @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                    {
                        <a class="!flex items-center gap-2 no-underline text-white hover:text-purple-400 transition-all" asp-action="Genres" asp-controller="Genre">
                            <i class="bi bi-grid-3x3-gap text-purple-400 text-xl"></i>
                            <span class="font-medium">Genres</span>
                        </a>
                    }

                    <a class="!flex items-center gap-2 no-underline text-white hover:text-purple-400 transition-all" asp-action="MyWatchList" asp-controller="WatchList">
                        <i class="bi bi-bookmark-star text-purple-400 text-xl"></i>
                        <span class="font-medium">Watch List</span>
                    </a>
                </div>

                <div class="flex flex-row items-center gap-8">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a class="!flex items-center gap-2 no-underline text-white hover:text-purple-400 transition-all" asp-action="Profile" asp-controller="Account">
                            <i class="bi bi-person-circle text-purple-400 text-xl"></i>
                            <span class="font-medium">Profile</span>
                        </a>
                        <a class="!flex items-center gap-2 no-underline text-white hover:text-purple-400 transition-all" asp-action="SignOut" asp-controller="Account">
                            <i class="bi bi-box-arrow-right text-purple-400 text-xl"></i>
                            <span class="font-medium">Sign Out</span>
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>
    <main class="pt-32 pb-24 px-6 md:px-12 max-w-7xl mx-auto">
        <!-- Hero Profile Section -->
        <section class="relative mb-20">
            <div class="flex flex-col md:flex-row items-center md:items-end gap-8 md:gap-12">
                <div class="relative group">
                    <div class="absolute -inset-1 bg-gradient-to-tr from-purple-600 to-purple-400 rounded-full blur opacity-25"></div>

                    <div class="relative h-40 w-40 md:h-52 md:w-52 rounded-full overflow-hidden border-4 border-slate-900 shadow-2xl bg-slate-800 flex items-center justify-center">
                        @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
                        {
                            <img class="h-full w-full object-cover"
                                 src="@Model.ProfileImageUrl"
                                 alt="@Model.FName @Model.LName" />
                        }
                        else
                        {
                            <span class="material-symbols-outlined text-6xl text-purple-400">person</span>
                        }
                    </div>
                </div>

                <div class="text-center md:text-left">
                    <h1 class="text-5xl md:text-7xl font-extrabold tracking-tighter text-white mb-4">
                        @Model.FName @Model.LName
                    </h1>

                    <div class="flex flex-wrap justify-center md:justify-start gap-6 text-slate-400 font-body text-sm">
                        <span class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-purple-500 text-lg">calendar_today</span>
                            Joined @Model.JoiningDate.ToString("yyyy MMMM dd")
                        </span>

                        <span class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-purple-500 text-lg" style="font-variation-settings: 'FILL' 1;">star</span>
                            @Model.LastReviews.Count() Reviews
                        </span>

                        <span class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-purple-500 text-lg">mail</span>
                            @Model.Email
                        </span>
                    </div>
                </div>

                <div class="flex gap-4">
                    <a asp-action="EditProfile" asp-controller="Account"
                       class="bg-purple-600 text-white px-8 py-3 rounded-full font-bold text-sm tracking-wide hover:scale-105 transition-transform shadow-lg shadow-purple-500/20">
                        Edit Profile
                    </a>
                </div>
            </div>
        </section>

        <div class="flex border-b border-white/10 mb-12 overflow-x-auto" id="profileTabs">
            <button onclick="switchTab('reviews')" id="btn-reviews"
                    class="px-8 py-4 text-white border-b-2 border-purple-500 font-bold text-lg whitespace-nowrap transition-all">
                My Reviews (@Model.LastReviews.Count())
            </button>
            <button onclick="switchTab('watchlist')" id="btn-watchlist"
                    class="px-8 py-4 text-slate-400 hover:text-white font-medium text-lg transition-colors whitespace-nowrap">
                Watchlist (@Model.WatchList.Count())
            </button>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
            <div id="tab-reviews" class="lg:col-span-8 space-y-8">
                @if (Model.LastReviews.Any())
                {
                    @foreach (var review in Model.LastReviews)
                    {
                        <article class="bg-slate-900/50 rounded-xl overflow-hidden flex flex-col md:flex-row group transition-all duration-300 border border-white/5 hover:border-purple-500/30">
                            <div class="w-full md:w-48 h-72 md:h-auto overflow-hidden">

                                <a asp-action="Details" asp-controller="Movie" asp-route-id="@review.MovieId">
                                    <img class="h-full w-full object-cover group-hover:scale-110 transition-transform duration-500"
                                         src="@review.Movie.Image_Name"
                                         alt="@review.Movie.Title" />
                                </a>
                            </div>

                            <div class="p-8 flex-1 flex flex-col">
                                <div class="flex justify-between items-start mb-4">
                                    <div>
                                        <h3 class="text-2xl font-bold text-white mb-1">@review.Movie.Title</h3>
                                        <p class="text-sm text-slate-400">Reviewed on @review.DatePosted.ToString("MMM dd, yyyy")</p>
                                    </div>
                                    <div class="bg-white/5 px-3 py-1 rounded-full flex items-center gap-1 border border-white/10">
                                        <span class="material-symbols-outlined text-purple-500 text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
                                        <span class="font-bold text-sm text-white">@(review.Score?.ToString("0.0") ?? "0.0")</span>
                                    </div>
                                </div>

                                <p class="text-slate-300 font-body leading-relaxed mb-6 italic">
                                    "@review.ReviewText"
                                </p>

                                <div class="mt-auto flex items-center gap-6">
                                    <button class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-slate-400 hover:text-purple-400 transition-colors">
                                        <span class="material-symbols-outlined text-lg">favorite</span> 0 Likes
                                    </button>
                                    <button class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-slate-400 hover:text-purple-400 transition-colors">
                                        <span class="material-symbols-outlined text-lg">chat_bubble</span> 0 Comments
                                    </button>
                                </div>
                            </div>
                        </article>
                    }
                }
                else
                {
                    <div class="text-center py-20 bg-slate-900/20 rounded-xl border border-dashed border-white/10">
                        <p class="text-slate-400">You haven't written any reviews yet.</p>
                    </div>
                }
            </div>

            <div id="tab-watchlist" class="lg:col-span-8 hidden space-y-8">
                <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
                    @foreach (var movie in Model.WatchList)
                    {
                        <a asp-action="Details" asp-controller="Movie" asp-route-id="@movie.Id" class="relative group rounded-xl overflow-hidden border border-white/5">
                            <img src="@movie.Image_Name" class="w-full h-64 object-cover" />
                            <div class="absolute inset-0 bg-gradient-to-t from-black to-transparent p-4 flex flex-col justify-end">
                                <h5 class="text-white font-bold">@movie.Title</h5>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
        </main>
</body>
</html>
<script>
    function switchTab(tab) {
        const reviews = document.getElementById('tab-reviews');
        const watchlist = document.getElementById('tab-watchlist');
        const btnRev = document.getElementById('btn-reviews');
        const btnWatch = document.getElementById('btn-watchlist');

        if (tab === 'reviews') {
            reviews.classList.remove('hidden');
            watchlist.classList.add('hidden');
            btnRev.className = "px-8 py-4 text-white border-b-2 border-purple-500 font-bold text-lg whitespace-nowrap";
            btnWatch.className = "px-8 py-4 text-slate-400 hover:text-white font-medium text-lg transition-colors whitespace-nowrap";
        } else {
            reviews.classList.add('hidden');
            watchlist.classList.remove('hidden');
            btnWatch.className = "px-8 py-4 text-white border-b-2 border-purple-500 font-bold text-lg whitespace-nowrap";
            btnRev.className = "px-8 py-4 text-slate-400 hover:text-white font-medium text-lg transition-colors whitespace-nowrap";
        }
    }
</script>