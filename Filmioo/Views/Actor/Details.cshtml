@model Demo.PL.ViewModels.ActorViewModel
@inject Demo.BLL.Interfaces.IUnitOfWork UnitOfWork
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Filmioo | @Model.FirstName @Model.LastName</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="~/css/actors.css" rel="stylesheet" asp-append-version="true" />
    <style>
        :root {
            --filmioo-black: #121212; 
            --filmioo-purple-main: #9333ea; 
            --filmioo-purple-light: #c084fc; 
            --filmioo-text-color: #f0f0f0; 
        }
        body {
            background-color: #0b0b0f;
            color: #ffffff;
            font-family: 'Segoe UI', sans-serif;
        }

        .navbar {
            background-color: #000;
            box-shadow: 0 0 15px rgba(138,43,226,.5);
        }

        .navbar-brand {
            color: #b45cff !important;
            font-weight: 800;
            font-size: 1.6rem;
        }

        .movie-container {
            margin-top: 60px;
        }

        .movie-card {
            background: linear-gradient(145deg, #140018, #000);
            border-radius: 18px;
            padding: 30px;
            box-shadow: 0 0 30px rgba(138,43,226,.35);
        }

        .movie-poster {
            width: 100%;
            border-radius: 16px;
            box-shadow: 0 0 25px rgba(138,43,226,.7);
        }

        .movie-title {
            color: #b45cff;
            font-weight: 800;
        }

        .movie-meta span {
            margin-right: 20px;
            color: #cfa7ff;
        }

        .description {
            margin-top: 20px;
            line-height: 1.8;
            color: #ddd;
        }

        .details-list {
            list-style: none;
            padding: 0;
        }

            .details-list li {
                margin-bottom: 6px;
            }

        .btn-purple {
            background-color: #8a2be2;
            color: #fff;
            border-radius: 30px;
            padding: 10px 25px;
            transition: .3s;
        }
        
        .filmioo-navbar {
            background-color: rgba(0, 0, 0, 0.9);
            border-bottom: 3px solid var(--filmioo-purple-main);
        }

        .filmioo-logo {
            color: var(--filmioo-purple-main) !important;
            font-size: 1.6rem;
            font-weight: 700;
            text-shadow: 0 0 8px var(--filmioo-purple-light);
        }

        
        .filmioo-nav-link {
            display: flex;
            align-items: center;
            color: var(--filmioo-text-color) !important;
            
            font-size: 0.9rem !important;
            font-weight: 400;
            letter-spacing: 0.3px;
            padding: 0.5rem 0.75rem !important;
            transition: all 0.25s ease-in-out;
            opacity: 0.85;
        }

            
            .filmioo-nav-link i {
                font-size: 1rem; 
                margin-right: 6px; 
                color: var(--filmioo-purple-light); 
            }

            .filmioo-nav-link:hover {
                color: #fff !important;
                opacity: 1;
                transform: translateY(-1px); 
                text-shadow: 0 0 10px rgba(187, 134, 252, 0.4);
            }

        .nav-auth-link {
            font-weight: 500;
            opacity: 0.95;
        }


        .btn-purple:hover {
            background-color: #a855f7;
            box-shadow: 0 0 15px #8a2be2;
        }

        .reviews-section {
            margin-top: 70px;
        }

        .section-title {
            color: #b45cff;
            margin-bottom: 30px;
        }

        .add-review {
            background: #120015;
            padding: 25px;
            border-radius: 16px;
            box-shadow: 0 0 20px rgba(138,43,226,.3);
        }

        .review-text {
            background-color: #0b0b0f;
            color: white;
            border: 1px solid #8a2be2;
        }
        .filmioo-navbar {
            background-color: rgba(0, 0, 0, 0.9); 
            border-bottom: 3px solid var(--filmioo-purple-main);
        }

        .filmioo-logo {
            color: var(--filmioo-purple-main) !important;
            font-size: 1.6rem;
            font-weight: 700;
            text-shadow: 0 0 8px var(--filmioo-purple-light);
        }

        .filmioo-nav-link,
        .filmioo-icon {
            color: var(--filmioo-text-color) !important;
            font-size: 1rem;
            font-weight: 500;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
        }

            .filmioo-nav-link:hover,
            .filmioo-icon:hover {
                color: var(--filmioo-purple-light) !important;
                text-shadow: 0 0 8px var(--filmioo-purple-light);
                transform: translateY(-2px);
            }

        .nav-auth-link {
            font-weight: 600; 
            opacity: 0.9;
        }
        .star-rating {
            display: flex;
            flex-direction: row-reverse;
            justify-content: start;
        }

            .star-rating input {
                display: none;
            }

            .star-rating label {
                font-size: 32px;
                color: #333;
                cursor: pointer;
                transition: .3s;
            }
        .film-item-card {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(138, 43, 226, 0.2);
            border-radius: 12px;
            padding: 15px;
            transition: all 0.3s ease;
            cursor: pointer;
        }

            .film-item-card:hover {
                background: rgba(138, 43, 226, 0.1);
                border-color: var(--filmioo-purple-light);
                transform: translateX(5px);
                box-shadow: -5px 0 15px rgba(138, 43, 226, 0.3);
            }

        .film-icon {
            width: 40px;
            height: 40px;
            background: var(--filmioo-purple-main);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.2rem;
        }

        .filmioo-poster-link {
            text-decoration: none !important;
            color: inherit;
        }

        .filmioo-mini-card {
            transition: all 0.3s ease;
        }

        .poster-wrapper {
            position: relative;
            aspect-ratio: 2/3; 
            overflow: hidden;
            border-radius: 12px;
            border: 2px solid rgba(147, 51, 234, 0.2);
            box-shadow: 0 5px 15px rgba(0,0,0,0.5);
            background: #000;
        }

            .poster-wrapper img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.5s ease;
            }
        .poster-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(138, 43, 226, 0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

            .poster-overlay i {
                font-size: 2.5rem;
                color: white;
                text-shadow: 0 0 15px rgba(0,0,0,0.5);
            }

        .filmioo-mini-card:hover .poster-wrapper {
            border-color: var(--filmioo-purple-light);
            transform: translateY(-8px);
            box-shadow: 0 10px 25px rgba(147, 51, 234, 0.5);
        }

        .filmioo-mini-card:hover img {
            transform: scale(1.1);
        }

        .filmioo-mini-card:hover .poster-overlay {
            opacity: 1;
        }

        .mini-card-info {
            padding-top: 10px;
            text-align: center;
        }

            .mini-card-info h6 {
                font-size: 0.9rem;
                margin-bottom: 2px;
                font-weight: 600;
            }

            .mini-card-info small {
                font-size: 0.8rem;
                color: var(--filmioo-purple-light) !important;
            }
        .text-purple {
            color: var(--filmioo-purple-light) !important;
        }

        .btn-delete {
            border-radius: 12px;
            padding: 8px 18px;
            font-weight: 600;
            transition: all 0.3s ease;
            border: 1px solid #ff4d4d;
            color: #ff4d4d;
            background: transparent;
            white-space: nowrap; 
        }

            .btn-delete:hover {
                background-color: #ff4d4d;
                color: #fff;
                box-shadow: 0 0 20px rgba(255, 77, 77, 0.6);
            }
        .section-title {
            font-size: 1.5rem;
            font-weight: 700;
            border-left: 4px solid var(--filmioo-purple-main);
            padding-left: 15px;
        }
        .actors-section {
            margin-top: 30px;
        }

        .actor-card {
            text-align: center;
            transition: .3s;
        }

            .actor-card img {
                width: 90px;
                height: 90px;
                object-fit: cover;
                border-radius: 50%;
                border: 3px solid #8a2be2;
                box-shadow: 0 0 15px rgba(138,43,226,.6);
            }

            .actor-card h6 {
                margin-top: 10px;
                font-size: 0.9rem;
                color: #ddd;
            }

            .actor-card:hover {
                transform: translateY(-6px);
            }


        .trailer-section {
            background: linear-gradient(145deg, #140018, #000);
            padding: 25px;
            border-radius: 16px;
            box-shadow: 0 0 35px rgba(138,43,226,.5);
        }

            .trailer-section h3 {
                color: #b45cff;
                margin-bottom: 20px;
                font-weight: 700;
            }

        .star-rating input:checked ~ label,
        .star-rating label:hover,
        .star-rating label:hover ~ label {
            color: #8a2be2;
        }
        .filmioo-modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(5px);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
            z-index: 9999;
        }

            .filmioo-modal-overlay:target {
                opacity: 1;
                pointer-events: auto;
            }

        .filmioo-modal-content {
            background: linear-gradient(145deg, #1a0022, #0b0b0f);
            padding: 40px;
            border-radius: 20px;
            border: 1px solid var(--filmioo-purple-main);
            text-align: center;
            max-width: 400px;
            box-shadow: 0 0 30px rgba(147, 51, 234, 0.4);
            transform: scale(0.8);
            transition: transform 0.3s ease;
        }

        .filmioo-modal-overlay:target .filmioo-modal-content {
            transform: scale(1);
        }

        .warning-icon {
            font-size: 4rem;
            color: #ff4d4d;
            margin-bottom: 20px;
        }

        .modal-actions {
            display: flex;
            gap: 15px;
            margin-top: 30px;
            justify-content: center;
        }

        .btn-cancel {
            text-decoration: none;
            color: #bbb;
            padding: 10px 20px;
            border-radius: 8px;
            transition: 0.3s;
        }

            .btn-cancel:hover {
                color: #fff;
                background: rgba(255,255,255,0.1);
            }

        .btn-confirm {
            text-decoration: none;
            background: #ff4d4d;
            color: white;
            padding: 10px 25px;
            border-radius: 8px;
            font-weight: bold;
            box-shadow: 0 4px 15px rgba(255, 77, 77, 0.3);
        }

            .btn-confirm:hover {
                background: #ff2a2a;
                box-shadow: 0 0 20px rgba(255, 77, 77, 0.5);
            }
        .review-card {
            background: #0f0013;
            padding: 20px;
            border-radius: 16px;
            margin-top: 20px;
            box-shadow: 0 0 12px rgba(138,43,226,.25);
        }

        .review-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        footer {
            margin-top: 80px;
            padding: 20px;
            text-align: center;
            color: #777;
        }

    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg filmioo-navbar sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand filmioo-logo" asp-action="Index" asp-controller="Home">Filmioo</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link filmioo-nav-link" asp-action="Movies" asp-controller="Movie">
                            <i class="bi bi-film me-1"></i> <span>Movies</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link filmioo-nav-link" asp-action="Genres" asp-controller="Genre">
                            <i class="bi bi-grid-3x3-gap"></i> <span>Genres</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link filmioo-nav-link" asp-action="MyWatchList" asp-controller="WatchList">
                            <i class="bi bi-bookmark-star"></i> <span>Watch List</span>
                        </a>
                    </li>

                </ul>

                <ul class="navbar-nav filmioo-icon-nav">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link filmioo-nav-link nav-auth-link" asp-action="Profile" asp-controller="Account" title="Profile">
                                <i class="bi bi-person-circle filmioo-icon"></i><span>Profile</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link filmioo-nav-link nav-auth-link" asp-action="SignOut" asp-controller="Account" title="Sign Out">
                                <i class="bi bi-box-arrow-right filmioo-icon"></i><span>Sign Out</span>
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link filmioo-nav-link nav-auth-link" asp-action="Login" asp-controller="Account">
                                <i class="bi bi-box-arrow-in-right"></i> <span>Login</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link filmioo-nav-link nav-auth-link" asp-action="Register" asp-controller="Account">
                                <i class="bi bi-person-plus"></i> <span>Register</span>
                            </a>
                        </li>
                    }
                </ul>
            </div>

        </div>
    </nav>

    <div class="container movie-container">
        <div class="movie-card row mb-4" data-aos="fade-up">
            <div class="col-lg-4 text-center mb-4">
                <img src="@Model.ProfileImageUrl" class="movie-poster" alt="@Model.FirstName"
                     style="max-width: 300px; border: 4px solid #8a2be2;" />
            </div>
            <div class="col-lg-8">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h1 class="movie-title">@Model.FirstName @Model.LastName</h1>
                </div>
                <div class="movie-meta mb-3">
                    @if (!string.IsNullOrEmpty(Model.Nationality))
                    {
                        <span><i class="fa-solid fa-earth-americas"></i> @Model.Nationality</span>
                    }
                    @if (Model.DateOfBirth.HasValue)
                    {
                        <span><i class="fa-solid fa-cake-candles"></i> @Model.DateOfBirth.Value.ToShortDateString()</span>
                    }
                </div>
                <h5 class="text-purple"><i class="fa-solid fa-address-card"></i> Biography</h5>
                <p class="description">@(string.IsNullOrEmpty(Model.Bio) ? "No biography available." : Model.Bio)</p>
            </div>
        </div>

        <div class="movie-card mt-4" data-aos="fade-up">
            <h3 class="section-title mb-4">
                <i class="fa-solid fa-clapperboard"></i> Filmography
            </h3>

            <div class="row row-cols-2 row-cols-md-4 row-cols-lg-6 g-4">
                @if (Model.Movies != null && Model.Movies.Any())
                {
                    @foreach (var movieActor in Model.Movies)
                    {
                        <div class="col">
                            <a asp-action="Details" asp-controller="Movie" asp-route-id="@movieActor.MovieId" class="filmioo-poster-link">
                                <div class="filmioo-mini-card">
                                    <div class="poster-wrapper">
                                        <img src="@movieActor.Movie?.Image_Name" class="img-fluid" alt="@movieActor.Movie?.Title">
                                    </div>
                                    <div class="mini-card-info">
                                        <h6 class="text-truncate">@movieActor.Movie?.Title</h6>
                                        <small class="text-muted">@movieActor.Movie?.Release_Date?.Year</small>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12"><p class="text-muted">No movies listed for this actor.</p></div>
                }
            </div>
        </div>
    </div>

    <footer>
        &copy; 2026 Filmioo &mdash; Movies made better
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 900, once: true });
    </script>
</body>
</html>
