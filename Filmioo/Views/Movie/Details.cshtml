@using System.Security.Claims
@using System.Text.Encodings.Web
@model Demo.PL.ViewModels.MovieViewModel
@inject Demo.BLL.Interfaces.IUnitOfWork UnitOfWork
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Filmioo | @Model.Title</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        :root {
            --filmioo-black: #121212; 
            --filmioo-purple-main: #9333ea; 
            --filmioo-purple-light: #c084fc; 
            --filmioo-text-color: #f0f0f0; 
        }
        body {
            background-color: #0b0b0f;
            color: #ffffff;
            font-family: 'Segoe UI', sans-serif;
        }


        .movie-container {
            margin-top: 60px;
        }

        .movie-card {
            background: linear-gradient(145deg, #140018, #000);
            border-radius: 18px;
            padding: 30px;
            box-shadow: 0 0 30px rgba(138,43,226,.35);
        }

        .movie-poster {
            width: 100%;
            border-radius: 16px;
            box-shadow: 0 0 25px rgba(138,43,226,.7);
        }

        .movie-title {
            color: #b45cff;
            font-weight: 800;
        }

        .movie-meta span {
            margin-right: 20px;
            color: #cfa7ff;
        }

        .description {
            margin-top: 20px;
            line-height: 1.8;
            color: #ddd;
        }

        .details-list {
            list-style: none;
            padding: 0;
        }

        .details-list li {
            margin-bottom: 6px;
        }

        .btn-purple {
            background-color: #8a2be2;
            color: #fff;
            border-radius: 30px;
            padding: 10px 25px;
            transition: .3s;
        }
        .filmioo-navbar {
            background-color: rgba(0, 0, 0, 0.9);
            border-bottom: 3px solid var(--filmioo-purple-main);
        }

        .filmioo-logo {
            color: var(--filmioo-purple-main) !important;
            font-size: 1.6rem;
            font-weight: 700;
            text-shadow: 0 0 8px var(--filmioo-purple-light);
        }

        .filmioo-nav-link {
            display: flex;
            align-items: center;
            color: var(--filmioo-text-color) !important;
            font-size: 0.9rem !important;
            font-weight: 400;
            letter-spacing: 0.3px;
            padding: 0.5rem 0.75rem !important;
            transition: all 0.25s ease-in-out;
            opacity: 0.85;
        }

            .filmioo-nav-link i {
                font-size: 1rem; 
                margin-right: 6px; 
                color: var(--filmioo-purple-light); 
            }

            .filmioo-nav-link:hover {
                color: #fff !important;
                opacity: 1;
                transform: translateY(-1px); 
                text-shadow: 0 0 10px rgba(187, 134, 252, 0.4);
            }

        .nav-auth-link {
            font-weight: 500;
            opacity: 0.95;
        }


        .btn-purple:hover {
            background-color: #a855f7;
            box-shadow: 0 0 15px #8a2be2;
        }

        .reviews-section {
            margin-top: 70px;
        }

        .section-title {
            color: #b45cff;
            margin-bottom: 30px;
        }

        .add-review {
            background: #120015;
            padding: 25px;
            border-radius: 16px;
            box-shadow: 0 0 20px rgba(138,43,226,.3);
        }

        .review-text {
            background-color: #0b0b0f;
            color: white;
            border: 1px solid #8a2be2;
        }

        .star-rating {
            display: flex;
            flex-direction: row-reverse;
            justify-content: start;
        }

        .star-rating input {
            display: none;
        }

        .star-rating label {
            font-size: 32px;
            color: #333;
            cursor: pointer;
            transition: .3s;
        }

        .actors-section {
            padding: 20px 0;
        }

        .section-title {
            color: #ffffff;
            font-weight: 700;
        }

        .btn-show-all {
            color: var(--filmioo-purple-light);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
            transition: all 0.3s ease;
            border: 1px solid rgba(138, 43, 226, 0.3);
            padding: 6px 16px;
            border-radius: 20px;
            background: transparent;
        }

            .btn-show-all:hover {
                background: var(--filmioo-purple-main);
                color: white;
                border-color: var(--filmioo-purple-main);
                box-shadow: 0 0 15px rgba(138, 43, 226, 0.4);
            }

        .actor-profile-card {
            position: relative;
            text-align: center;
            padding: 15px 10px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 16px;
            border: 1px solid rgba(138, 43, 226, 0.1);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            cursor: pointer;
            overflow: hidden; 
            height: 100%;
            z-index: 1;
        }

            .actor-profile-card:hover {
                transform: translateY(-8px);
                background: rgba(147, 51, 234, 0.08);
                border-color: var(--filmioo-purple-light);
                box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
            }

        .actor-image-container {
            position: relative;
            width: 110px;
            height: 110px;
            margin: 0 auto 12px; 
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .actor-main-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
            border: 3px solid var(--filmioo-purple-main);
            position: relative;
            z-index: 2; 
            transition: all 0.4s ease;
        }

        .actor-glow {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%); 
            width: 90%;
            height: 90%;
            background: var(--filmioo-purple-main);
            filter: blur(20px);
            opacity: 0.35;
            border-radius: 50%;
            z-index: 1; 
            transition: all 0.4s ease;
        }

        .actor-profile-card:hover .actor-main-img {
            transform: scale(1.05);
            border-color: var(--filmioo-purple-light);
            box-shadow: 0 0 15px rgba(147, 51, 234, 0.3);
        }

        .actor-profile-card:hover .actor-glow {
            opacity: 0.7;
            filter: blur(25px);
            transform: translate(-50%, -50%) scale(1.2);
            background: var(--filmioo-purple-light);
        }

        .actor-details {
            position: relative;
            z-index: 3;
        }

        .actor-full-name {
            font-size: 0.95rem;
            font-weight: 700;
            color: #ffffff;
            margin: 0;
            line-height: 1.2;
        }

        .actor-label {
            font-size: 0.65rem;
            color: var(--filmioo-purple-light);
            text-transform: uppercase;
            font-weight: 600;
            letter-spacing: 1px;
            display: block;
            margin-top: 4px;
        }


        .trailer-section {
            background: linear-gradient(145deg, #140018, #000);
            padding: 30px;
            border-radius: 16px;
            box-shadow: 0 0 35px rgba(138,43,226,.5);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

            .trailer-section h3 {
                color: #b45cff;
                margin-top: 0;
                margin-bottom: 25px; 
                font-weight: 700;
                text-align: center;
            }

            .trailer-section .ratio {
                border-radius: 12px;
                overflow: hidden;
                box-shadow: 0 0 15px rgba(0,0,0,0.5);
            }

        .star-rating input:checked ~ label,
        .star-rating label:hover,
        .star-rating label:hover ~ label {
            color: #8a2be2;
        }
        .btn-delete {
            border-radius: 12px;
            padding: 8px 18px;
            font-weight: 600;
            transition: all 0.3s ease;
            border: 1px solid #ff4d4d;
            color: #ff4d4d;
            background: transparent;
            white-space: nowrap; 
        }

            .btn-delete:hover {
                background-color: #ff4d4d;
                color: #fff;
                box-shadow: 0 0 20px rgba(255, 77, 77, 0.6);
            }

        @@media (max-width: 768px) {
            .movie-card .d-flex {
                flex-direction: column;
            }

            .btn-delete {
                margin-top: 15px;
            }
        }
        .poster-wrapper {
            position: relative;
            display: inline-block; 
            width: 100%;
        }

        .filmioo-modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(5px);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
            z-index: 9999;
        }

            .filmioo-modal-overlay:target {
                opacity: 1;
                pointer-events: auto;
            }

        .filmioo-modal-content {
            background: linear-gradient(145deg, #1a0022, #0b0b0f);
            padding: 40px;
            border-radius: 20px;
            border: 1px solid var(--filmioo-purple-main);
            text-align: center;
            max-width: 400px;
            box-shadow: 0 0 30px rgba(147, 51, 234, 0.4);
            transform: scale(0.8);
            transition: transform 0.3s ease;
        }

        .filmioo-modal-overlay:target .filmioo-modal-content {
            transform: scale(1);
        }
        .warning-icon {
            font-size: 4rem;
            color: #ff4d4d;
            margin-bottom: 20px;
        }

        .modal-actions {
            display: flex;
            gap: 15px;
            margin-top: 30px;
            justify-content: center;
        }

        .btn-cancel {
            text-decoration: none;
            color: #bbb;
            padding: 10px 20px;
            border-radius: 8px;
            transition: 0.3s;
        }

            .btn-cancel:hover {
                color: #fff;
                background: rgba(255,255,255,0.1);
            }

        .btn-confirm {
            text-decoration: none;
            background: #ff4d4d;
            color: white;
            padding: 10px 25px;
            border-radius: 8px;
            font-weight: bold;
            box-shadow: 0 4px 15px rgba(255, 77, 77, 0.3);
        }

            .btn-confirm:hover {
                background: #ff2a2a;
                box-shadow: 0 0 20px rgba(255, 77, 77, 0.5);
            }

        .watchlist-btn {
            position: absolute;
            top: 15px;
            right: 15px;
            background: rgba(0, 0, 0, 0.7);
            color: #ffffff !important;
            width: 42px;
            height: 42px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            font-size: 1.3rem;
            text-decoration: none;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border: 1px solid rgba(180, 92, 255, 0.5);
            box-shadow: 0 0 10px rgba(138, 43, 226, 0.3);
            backdrop-filter: blur(8px);
            z-index: 10;
        }

            .watchlist-btn:hover {
                color: #ffffff !important;
                background: #9333ea !important;
                transform: scale(1.15) rotate(90deg);
                box-shadow: 0 0 20px rgba(147, 51, 234, 0.8);
                border-color: #ffffff;
            }

            .watchlist-btn i {
                transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            }

            .watchlist-btn.in-watchlist {
                background: rgba(0, 0, 0, 0.7);
            }

        .fa-check, .fa-plus {
            animation: scaleIn 0.3s ease;
        }

        @@keyframes scaleIn {
            0% {
                transform: scale(0);
            }

            100% {
                transform: scale(1);
            }
        }

        .btn-action.cast {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            border: 1.5px solid #10b981; 
            border-radius: 12px;
            background: transparent;
            color: #10b981;
            text-decoration: none;
            font-weight: 500;
            font-size: 0.9rem;
            transition: all 0.3s ease;
        }

            .btn-action.cast:hover {
                background-color: #10b981;
                color: #ffffff;
                box-shadow: 0 0 15px rgba(16, 185, 129, 0.5);
                transform: scale(1.05);
            }

            .btn-action.cast i {
                font-size: 1rem;
            }
            .watchlist-btn:hover {
                color: #ffffff;
                background: #9333ea;
                transform: scale(1.15) rotate(90deg); 
                box-shadow: 0 0 20px rgba(147, 51, 234, 0.8);
            }

        .navbar-toggler {
            border-color: var(--filmioo-purple-main) !important;
        }

        .navbar-toggler-icon {
            filter: invert(44%) sepia(96%) saturate(1915%) hue-rotate(249deg) brightness(97%) contrast(96%);
        }

        @@media (max-width: 991.98px) {
            .navbar-collapse {
                background-color: #000;
                padding: 15px;
                border-radius: 10px;
                margin-top: 10px;
                border: 1px solid var(--filmioo-purple-main);
            }
        }
        .movie-genres {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .genre-badge {
            background: rgba(147, 51, 234, 0.1); 
            color: var(--filmioo-purple-light);
            border: 1px solid rgba(138, 43, 226, 0.3);
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
            cursor: default;
        }

            .genre-badge:hover {
                background: var(--filmioo-purple-main);
                color: #ffffff;
                border-color: var(--filmioo-purple-main);
                box-shadow: 0 0 10px rgba(138, 43, 226, 0.5);
                transform: translateY(-2px);
            }
        

        .review-card {
            background: #0f0013;
            padding: 20px;
            border-radius: 16px;
            margin-top: 20px;
            box-shadow: 0 0 12px rgba(138,43,226,.25);
        }

        .review-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .btn-text-edit {
            color: #94a3b8; 
            background: none;
            border: none;
            font-size: 0.85rem;
            transition: 0.3s;
        }

            .btn-text-edit:hover {
                color: #fff;
            }

        .btn-text-delete {
            color: #ef4444; 
            background: none;
            border: none;
            font-size: 0.85rem;
            opacity: 0.8;
        }

            .btn-text-delete:hover {
                opacity: 1;
            }

        .filmioo-modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(5px);
            display: none; 
            align-items: center;
            justify-content: center;
            z-index: 10000; 
        }

            .filmioo-modal-overlay:target {
                opacity: 1;
                pointer-events: auto;
            }

        .filmioo-modal-content {
            background: linear-gradient(145deg, #1a0022, #0b0b0f);
            padding: 40px;
            border-radius: 20px;
            border: 1px solid var(--filmioo-purple-main);
            text-align: center;
            max-width: 400px;
            width: 90%; 
            box-shadow: 0 0 30px rgba(147, 51, 234, 0.4);
        }

        .filmioo-modal-overlay:target .filmioo-modal-content {
            transform: scale(1);
        }

        .warning-icon {
            font-size: 4rem;
            color: #ff4d4d;
            margin-bottom: 20px;
        }

        .modal-actions {
            display: flex;
            gap: 15px;
            margin-top: 30px;
            justify-content: center;
        }

        .btn-cancel {
            text-decoration: none;
            color: #bbb;
            padding: 10px 20px;
            border-radius: 8px;
            transition: 0.3s;
        }

            .btn-cancel:hover {
                color: #fff;
                background: rgba(255,255,255,0.1);
            }

        .btn-confirm {
            text-decoration: none;
            background: #ff4d4d;
            color: white;
            padding: 10px 25px;
            border-radius: 8px;
            font-weight: bold;
            box-shadow: 0 4px 15px rgba(255, 77, 77, 0.3);
        }

            .btn-confirm:hover {

                background: #ff2a2a;
                box-shadow: 0 0 20px rgba(255, 77, 77, 0.5);
            }
        .border-purple {
            border: 2px solid #9333ea !important;
            box-shadow: 0 0 30px rgba(147, 51, 234, 0.4) !important;
        }

        .edit-icon {
            font-size: 3.5rem;
            color: #c084fc;
            margin-bottom: 15px;
        }

        .cosmic-input {
            background: rgba(255, 255, 255, 0.05) !important;
            border: 1px solid rgba(147, 51, 234, 0.3) !important;
            color: white !important;
        }

            .cosmic-input:focus {
                border-color: #9333ea !important;
                box-shadow: 0 0 10px rgba(147, 51, 234, 0.5) !important;
            }

        .modal-actions-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .btn-save-edit {
            background: #9333ea;
            color: white;
            border: none;
            padding: 12px;
            border-radius: 8px;
            font-weight: 600;
            transition: 0.3s;
        }

            .btn-save-edit:hover {
                background: #a855f7;
                box-shadow: 0 0 15px rgba(147, 51, 234, 0.6);
            }

        .btn-cancel-edit {
            background: transparent;
            color: #94a3b8;
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 12px;
            border-radius: 8px;
            transition: 0.3s;
        }

            .btn-cancel-edit:hover {
                background: rgba(255, 255, 255, 0.05);
                color: white;
            }

        footer {
            margin-top: 80px;
            padding: 20px;
            text-align: center;
            color: #777;
        }

    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg filmioo-navbar sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand filmioo-logo" asp-action="Index" asp-controller="Home">Filmioo</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link filmioo-nav-link" asp-action="Index" asp-controller="Actor">
                            <i class="bi bi-people"></i> <span>Actors</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link filmioo-nav-link" asp-action="Genres" asp-controller="Genre">
                            <i class="bi bi-grid-3x3-gap"></i> <span>Genres</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link filmioo-nav-link" asp-action="MyWatchList" asp-controller="WatchList">
                            <i class="bi bi-bookmark-star"></i> <span>Watch List</span>
                        </a>
                    </li>
                </ul>

                <ul class="navbar-nav filmioo-icon-nav">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link filmioo-nav-link nav-auth-link" asp-action="Profile" asp-controller="Account" title="Profile">
                                <i class="bi bi-person-circle filmioo-icon"></i><span>Profile</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link filmioo-nav-link nav-auth-link" asp-action="SignOut" asp-controller="Account" title="Sign Out">
                                <i class="bi bi-box-arrow-right filmioo-icon"></i><span>Sign Out</span>
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link filmioo-nav-link nav-auth-link" asp-action="Login" asp-controller="Account">
                                <i class="bi bi-box-arrow-in-right"></i> <span>Login</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link filmioo-nav-link nav-auth-link" asp-action="Register" asp-controller="Account">
                                <i class="bi bi-person-plus"></i> <span>Register</span>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container movie-container">
        <div class="movie-card row" data-aos="fade-up">
            <div class="col-lg-4 text-center mb-4">
                <div class="poster-wrapper">
                    <img src="@Model.Image_Name" class="card-img-top filmioo-card-img movie-poster" alt="@Model.Title">

                    @{
                        var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                        bool isInWatchlist = userId != null && Model.WatchList != null && Model.WatchList.Any(w => w.UserId == userId);
                    }

                    <a href="javascript:void(0);"
                       class="watchlist-btn @(isInWatchlist ? "in-watchlist" : "")"
                       data-movie-id="@Model.Id"
                       title="Watchlist">
                        <i class="fa-solid @(isInWatchlist ? "fa-check" : "fa-plus")"></i>
                    </a>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h1 class="movie-title m-0">@Model.Title</h1>
                    @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            <div class="d-flex gap-3">
                                <a asp-action="AssignGenres" asp-controller="Movie" class="btn-action cast">
                                    <i class="fa-solid fa-users"></i> Manage Genres
                                </a>
                            </div>
                        }
                    </div>

                <div class="movie-meta mb-3">
                    @{
                        var rating = await UnitOfWork.MovieRepository.GetAverageRating(Model.Id);
                    }
                    <span>
                        <i class="fa-solid fa-star"></i>
                        @(rating > 0 ? rating.ToString("0.0") : "N/A") / 10
                    </span>
                    <span>
                        <i class="fa-solid fa-clock"></i>
                        @{
                            var hours = Model.RuntimeInMinutes / 60;   
                            var minutes = Model.RuntimeInMinutes % 60; 
                        }
                        @hours h @minutes min
                    </span>
                    <span><i class="fa-solid fa-calendar"></i> @Model.Release_Date?.Year</span>
                </div>

                <p class="description">@Model.Description</p>

                <ul class="details-list">
                    <li><strong>Director:</strong> @Model.Director</li>
                    <li><strong>Author:</strong> @Model.Author</li>
                    <li><strong>Country:</strong> @Model.CountryOfOrigin</li>
                    <li><strong>Language:</strong> @Model.Language</li>
                </ul>

                <div class="movie-genres mt-3">
                    @foreach (var genre in Model.MovieGenres)
                    {
                        <span class="genre-badge">@genre.Genre.Name</span>
                    }
                </div>
            </div>
        </div>
        <br />
        <br />
        <div class="movie-card" data-aos="fade-up">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="section-title mb-0">
                    <i class="fa-solid fa-users"></i> Top Cast
                </h2>
                <div class="d-flex gap-3">
                    @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                    {
                        <a asp-action="AssignActors" asp-controller="Movie" class="btn-action cast">
                            <i class="fa-solid fa-users"></i> Manage Cast
                        </a>
                    }
                    <a asp-action="AllActors" asp-controller="Movie" asp-route-id="@Model.Id" class="btn-show-all">
                        Show All Actors <i class="fa-solid fa-chevron-right ms-1"></i>
                    </a>
                </div>
                
            </div>

            <div class="row g-4">
                @foreach (var actor in Model.Actors)
                {
                    <div class="col-6 col-md-4 col-lg-2">
                        <a asp-action="Details" asp-controller="Actor" asp-route-id="@actor.Id" class="actor-card-link">
                            <div class="actor-profile-card">
                                <div class="actor-image-container">
                                    <div class="actor-glow"></div>
                                    <img src="@actor.ProfileImageUrl" alt="@actor.FirstName" class="actor-main-img" />
                                </div>
                                <div class="actor-details">
                                    <h6 class="actor-full-name">@actor.FirstName @actor.LastName</h6>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
        <br />
        <br />
        <div class="movie-card row" data-aos="fade-up">
            <h2 class="section-title mb-4">
                <i class="fa-solid fa-film"></i> Official Trailer
            </h2>
            @if (!string.IsNullOrEmpty(Model.TrailerUrl))
            {
                var embedUrl = Model.TrailerUrl.Replace("watch?v=", "embed/");
                <div class="row mt-5 justify-content-center" data-aos="fade-up">
                    <div class="col-lg-10">
                            <div class="ratio ratio-16x9">
                                <iframe src="@embedUrl"
                                        title="@Model.Title Trailer"
                                        allowfullscreen>
                                </iframe>
                            </div>
                    </div>
                </div>
            }
        </div>

        <div class="reviews-section" data-aos="fade-up">
            <h2 class="section-title">Reviews & Ratings</h2>

            @{
                var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                var userReview = Model.Reviews?.FirstOrDefault(r => r.ApplicationUserId == currentUserId);
            }

            <div class="add-review mb-4">
                <h5>Add Your Review</h5>

                <form id="reviewForm" asp-action="AddReview" asp-controller="Movie" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="MovieId" value="@Model.Id" />

                    <div class="star-rating mb-3">
                        @for (int i = 10; i >= 1; i--)
                        {
                            <input type="radio" name="Score" value="@i" id="star-@i" />
                            <label for="star-@i">&#9733;</label>
                        }
                    </div>

                    <textarea name="ReviewText" class="form-control review-text" rows="4"
                              placeholder="Write your review..."></textarea>

                    <button type="submit" class="btn btn-purple mt-3">
                        Submit Review
                    </button>
                </form>
            </div>
            @if (Model.Reviews != null && Model.Reviews.Any())
            {
                @foreach (var review in Model.Reviews)
                {
                    <div class="review-card" id="review-@review.Id" data-aos="fade-up">
                        <div class="review-header flex justify-between">
                            <div>
                                <strong><i class="fa-solid fa-user"></i> @review.ApplicationUser.FName @review.ApplicationUser.LName</strong>
                                <span class="ms-3 text-warning">
                                    @for (int i = 0; i < (review.Score ?? 0); i++)
                                    {
                                        <i class="fa-solid fa-star"></i>
                                    }
                                </span>
                            </div>

                            @if (review.ApplicationUserId == currentUserId)
                            {
                                <div class="review-actions">
                                    <a href="#editReviewModal"
                                       class="btn-text-edit me-2 btn-edit-trigger text-decoration-none"
                                       onclick="openEditReviewModal('@review.Id', '@review.Score', '@Html.Raw(JavaScriptEncoder.Default.Encode(review.ReviewText ?? ""))')">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                    <a href="#delete-modal"
                                       class="btn-text-delete text-decoration-none"
                                       onclick="prepareMovieDelete('@review.Id', '@Model.Title')">
                                        <i class="fa-solid fa-trash"></i> Delete
                                    </a>

                                </div>
                            }
                        </div>
                        <p class="mt-2 text-slate-300">@review.ReviewText</p>
                    </div>
                }
            }
            else
            {
                <p class="text-muted">No reviews yet.</p>
            }
        </div>
    </div>

    <footer>
        &copy; 2026 Filmioo &mdash; Movies made better
    </footer>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <div id="delete-modal" class="filmioo-modal-overlay">
        <div class="filmioo-modal-content">
            <i class="fa-solid fa-circle-exclamation warning-icon"></i>
            <p>
                Are you sure you want to delete the review for: <br />
                <strong id="delete-movie-title" class="text-purple-400"></strong>?
            </p>

            <div class="modal-actions">
                <a href="#" class="btn-cancel">Cancel</a>

                <form asp-action="DeleteReview" asp-controller="Movie" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="delete-movie-id" />
                    <button type="submit" class="btn-confirm">Yes, Delete Review</button>
                </form>
            </div>
        </div>
    </div>
    <div id="editReviewModal" class="filmioo-modal-overlay">
        <div class="filmioo-modal-content border-purple">
            <i class="fa-solid fa-pen-to-square edit-icon"></i>
            <h3 class="text-white mb-1">Edit Your Review</h3>
            <p class="text-slate-400 mb-4">@Model.Title</p>

            <form id="editReviewForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editReviewId" name="Id" />

                <div class="mb-3 text-start">
                    <label class="form-label text-sm text-purple-300">Your Score (1-10)</label>
                    <input type="number" name="Score" id="editScore" min="1" max="10"
                           class="form-control cosmic-input" required />
                </div>

                <div class="mb-4 text-start">
                    <label class="form-label text-sm text-purple-300">Your Review</label>
                    <textarea name="ReviewText" id="editReviewText" rows="4"
                              class="form-control cosmic-input"></textarea>
                </div>

                <div class="modal-actions-grid">
                    <button type="submit" class="btn-save-edit">Save Changes</button>
                    <button type="button" class="btn-cancel-edit" onclick="closeEditModal()">Go Back</button>
                </div>
            </form>
        </div>
    </div>
    <script>
        AOS.init({ duration: 900, once: true });
    </script>

</body>
</html>
<script>
    $(document).ready(function () {
        window.openEditReviewModal = function (id, score, text) {
            $('#editReviewId').val(id);
            $('#editScore').val(score);
            $('#editReviewText').val(text);
            $('#editReviewModal').css('display', 'flex').hide().fadeIn(250);
        };

        window.closeEditModal = function () {
            $('#editReviewModal').fadeOut(250);
        };

        $('#editReviewForm').on('submit', function (e) {
            e.preventDefault();
            $.post('/Movie/EditReview', $(this).serialize(), function (response) {
                if (response.success) {
                    location.reload();
                } else {
                    alert("Update failed: " + response.message);
                }
            });
        });
    });
        $(document).ready(function () {
        $('#reviewForm').on('submit', function (e) {
            e.preventDefault(); 

            var form = $(this);
            var url = form.attr('action');
            var formData = form.serialize(); 

            $.post(url, formData, function (response) {
                if (response.success) {
                    location.reload();
                } else {
                    alert("Error: " + response.message);
                }
            }).fail(function () {
                alert("Something went wrong. Are you logged in?");
            });
        });
    });
        $(document).ready(function() {
        window.prepareMovieDelete = function(id, title) {
            $('#delete-movie-id').val(id);

            $('#delete-movie-title').text(title);

            $('#delete-modal').css('display', 'flex').hide().fadeIn(200);
        };

        $(document).on('click', '.btn-cancel', function(e) {
            e.preventDefault();
            $('#delete-modal').fadeOut(200);
        });

        $(document).on('click', '#delete-modal', function(e) {
            if (e.target === this) {
                $(this).fadeOut(200);
            }
        });
    });
    $(document).on('click', '.watchlist-btn', function (e) {
        e.preventDefault();
        var btn = $(this);
        var movieId = btn.data('movie-id');

        $.post('/WatchList/ToggleWatchlist', { movieId: movieId }, function (response) {
            if (response.success) {
                if (response.action === "added") {
                    btn.find('i').removeClass('fa-plus').addClass('fa-check');
                    btn.addClass('in-watchlist');
                } else {
                    btn.find('i').removeClass('fa-check').addClass('fa-plus');
                    btn.removeClass('in-watchlist');
                }
            }
        }).fail(function () {
            window.location.href = '/Account/Login'; 
        });
    });
</script>
