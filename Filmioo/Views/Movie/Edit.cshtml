@model UpdateMovieViewModel
@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/AddingLayout.cshtml";
}

<div class="background-animation"></div>
<div class="register-container">
    <div class="logo">🎬 Filmioo</div>
    <br />
    <h1>Update Movie</h1>
    <p class="text-slate-400">Modify the details for <strong>@Model.Title</strong></p>
    <br />

    <form asp-action="Edit" asp-controller="Movie" enctype="multipart/form-data" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ExistingImageName" />

        <div>
            <div class="form-row">
                <div class="form-group half-width">
                    <label asp-for="Title">Title</label>
                    <input asp-for="Title" required>
                    <span asp-validation-for="Title" class="error-message"></span>
                </div>
                <div class="form-group half-width">
                    <label class="col-form-label" asp-for="ImageFile">Update Poster</label>
                    <input class="form-control" asp-for="ImageFile" type="file" onchange="previewImage(this)" />
                    @if (!string.IsNullOrEmpty(Model.ExistingImageName))
                    {
                        <small class="text-purple-400">Current: @Model.ExistingImageName</small>
                    }
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Description">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3" required style="background: rgba(255,255,255,0.05); color: white; border: 1px solid rgba(255,255,255,0.1); width: 100%;"></textarea>
                    <span asp-validation-for="Description" class="error-message"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Release_Date">Release Date</label>
                    <input asp-for="Release_Date" type="date">
                    <span asp-validation-for="Release_Date" class="error-message"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group half-width">
                    <label asp-for="Author">Author</label>
                    <input asp-for="Author" required>
                    <span asp-validation-for="Author" class="error-message"></span>
                </div>
                <div class="form-group half-width">
                    <label asp-for="Director">Director</label>
                    <input asp-for="Director" required>
                    <span asp-validation-for="Director" class="error-message"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group half-width">
                    <label asp-for="RuntimeInMinutes">Runtime (Min)</label>
                    <input asp-for="RuntimeInMinutes" required>
                    <span asp-validation-for="RuntimeInMinutes" class="error-message"></span>
                </div>
                <div class="form-group half-width">
                    <label asp-for="TrailerUrl">Trailer URL</label>
                    <input asp-for="TrailerUrl">
                    <span asp-validation-for="TrailerUrl" class="error-message"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group half-width">
                    <label asp-for="CountryOfOrigin">Country</label>
                    <input asp-for="CountryOfOrigin">
                    <span asp-validation-for="CountryOfOrigin" class="error-message"></span>
                </div>
                <div class="form-group half-width">
                    <label asp-for="Language">Language</label>
                    <input asp-for="Language">
                    <span asp-validation-for="Language" class="error-message"></span>
                </div>
            </div>
        </div>

        <div class="mt-8 flex flex-row items-center justify-between gap-4 w-full">
            <div class="form-row">
                <div class="form-group half-width">
                    <button type="submit" class="register-button flex-1" style="margin: 0;">
                        Save Changes
                    </button>
                </div>
                <div class="form-group half-width">
                    <button asp-action="Movies" class="register-button flex-1" style="margin: 0;">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

