@model AssignGenreViewModel
@{
    ViewData["Title"] = "Assign Genres";
    Layout = "~/Views/Shared/AddingLayout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

<div class="background-animation"></div>

<div class="register-container">
    <div class="logo">🎬 Filmioo</div>
    <br />
    <h1>Assign Genres</h1>
    <p style="color: rgba(255,255,255,0.7); text-align: center;">Update the Genres for your favorite titles</p>
    <br />

    <form asp-action="AssignGenres" asp-controller="Movie" method="post">
        <div asp-validation-summary="ModelOnly" class="error-message"></div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="MovieId">1. Select Movie</label>
                <select asp-for="MovieId" class="form-control select2-single" asp-items="Model.MovieList">
                    <option value="">-- Search for a movie --</option>
                </select>
                <span asp-validation-for="MovieId" class="error-message"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="SelectedGenreIds">2. Assign Cast Members</label>
                <select asp-for="SelectedGenreIds" class="form-control select2-multiple"
                        asp-items="Model.GenreList" multiple="multiple">
                </select>
                <span asp-validation-for="SelectedGenreIds" class="error-message"></span>
            </div>
        </div>

        <div style="margin-top: 20px;">
            <input type="submit" value="Save Assignments" class="register-button" />
        </div>

        <div style="text-align: center; margin-top: 15px;">
            <a asp-action="Movies" style="color: #fff; text-decoration: none; font-size: 0.9rem; opacity: 0.8;">
                ← Back to Movies
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function () {
            // Apply the Filmioo style to Select2
            $('.select2-single').select2({
                theme: 'bootstrap-5',
                width: '100%'
            });

            $('.select2-multiple').select2({
                theme: 'bootstrap-5',
                placeholder: "Search and add actors...",
                allowClear: true,
                width: '100%',
                closeOnSelect: false
            });
        });
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

