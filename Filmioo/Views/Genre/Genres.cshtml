@model IEnumerable<GenreViewModel>
@{
    ViewData["Title"] = "All Genres";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Filmioo - Genres</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="~/css/Genres.css" rel="stylesheet" asp-append-version="true" />
    <style>
        .filmioo-navbar {
            background-color: rgba(0, 0, 0, 0.9);
            border-bottom: 3px solid var(--filmioo-purple-main);
        }

        .filmioo-logo {
            color: var(--filmioo-purple-main) !important;
            font-size: 1.6rem;
            font-weight: 700;
            text-shadow: 0 0 8px var(--filmioo-purple-light);
        }

        .filmioo-nav-link {
            display: flex;
            align-items: center;
            color: var(--filmioo-text-color) !important;
            font-size: 0.9rem !important;
            font-weight: 400;
            letter-spacing: 0.3px;
            padding: 0.5rem 0.75rem !important;
            transition: all 0.25s ease-in-out;
            opacity: 0.85;
        }

            .filmioo-nav-link i {
                font-size: 1rem; 
                margin-right: 6px; 
                color: var(--filmioo-purple-light); 
            }

            .filmioo-nav-link:hover {
                color: #fff !important;
                opacity: 1;
                transform: translateY(-1px); 
                text-shadow: 0 0 10px rgba(187, 134, 252, 0.4);
            }

        .nav-auth-link {
            font-weight: 500;
            opacity: 0.95;
        }
        .filmioo-modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(5px);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
            z-index: 9999;
        }

            .filmioo-modal-overlay:target {
                opacity: 1;
                pointer-events: auto;
            }

        .filmioo-modal-content {
            background: linear-gradient(145deg, #1a0022, #0b0b0f);
            padding: 40px;
            border-radius: 20px;
            border: 1px solid var(--filmioo-purple-main);
            text-align: center;
            max-width: 400px;
            box-shadow: 0 0 30px rgba(147, 51, 234, 0.4);
            transform: scale(0.8);
            transition: transform 0.3s ease;
        }

        .filmioo-modal-overlay:target .filmioo-modal-content {
            transform: scale(1);
        }

        .warning-icon {
            font-size: 4rem;
            color: #ff4d4d;
            margin-bottom: 20px;
        }

        .modal-actions {
            display: flex;
            gap: 15px;
            margin-top: 30px;
            justify-content: center;
        }

        .btn-cancel {
            text-decoration: none;
            color: #bbb;
            padding: 10px 20px;
            border-radius: 8px;
            transition: 0.3s;
        }

            .btn-cancel:hover {
                color: #fff;
                background: rgba(255,255,255,0.1);
            }

        .btn-confirm {
            text-decoration: none;
            background: #ff4d4d;
            color: white;
            padding: 10px 25px;
            border-radius: 8px;
            font-weight: bold;
            box-shadow: 0 4px 15px rgba(255, 77, 77, 0.3);
        }

            .btn-confirm:hover {
                background: #ff2a2a;
                box-shadow: 0 0 20px rgba(255, 77, 77, 0.5);
            }

        footer {
            margin-top: 80px;
            padding: 20px;
            text-align: center;
            color: #777;
        }
    </style>
</head>

<body>
    <nav class="navbar navbar-expand-lg filmioo-navbar sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand filmioo-logo" asp-action="Index" asp-controller="Home">Filmioo</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link filmioo-nav-link" asp-action="Movies" asp-controller="Movie">
                            <i class="bi bi-film me-1"></i> <span>Movies</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link filmioo-nav-link" asp-action="Index" asp-controller="Actor">
                            <i class="bi bi-people"></i> <span>Actors</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link filmioo-nav-link" asp-action="MyWatchList" asp-controller="WatchList">
                            <i class="bi bi-bookmark-star"></i> <span>Watch List</span>
                        </a>
                    </li>
                </ul>

                <ul class="navbar-nav filmioo-icon-nav">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link filmioo-nav-link nav-auth-link" asp-action="Profile" asp-controller="Account" title="Profile">
                                <i class="bi bi-person-circle filmioo-icon"></i><span>Profile</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link filmioo-nav-link nav-auth-link" asp-action="SignOut" asp-controller="Account" title="Sign Out">
                                <i class="bi bi-box-arrow-right filmioo-icon"></i><span>Sign Out</span>
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link filmioo-nav-link nav-auth-link" asp-action="Login" asp-controller="Account">
                                <i class="bi bi-box-arrow-in-right"></i> <span>Login</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link filmioo-nav-link nav-auth-link" asp-action="Register" asp-controller="Account">
                                <i class="bi bi-person-plus"></i> <span>Register</span>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <header class="container-fluid filmioo-hero-section py-5 mb-5 text-center">
        <h1 class="display-4">Discover, Review, Rate.</h1>
        <p class="lead">Your source for the latest movies and community ratings.</p>
    </header>
    @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
    {
        <div class="container text-center mb-5">
            <a asp-action="AddGenre" asp-controller="Genre" class="btn filmioo-add-btn">
                <i class="bi bi-plus-circle-fill"></i> Add New Genre
            </a>
        </div>
    }

    <main class="container pb-5">
        <div class="container mt-5">
            <h2 class="filmioo-heading mb-4">Movie Genres</h2>

            <div class="genre-grid">
                @foreach (var genre in Model)
                {
                    <div class="genre-card">
                        <a asp-action="Details" asp-controller="Genre" asp-route-id="@genre.GenreId" class="genre-link-wrapper text-decoration-none text-light">
                            <div class="genre-content">
                                <span class="genre-name ">@genre.Name</span>
                            </div>
                        </a>
                        @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            <div class="genre-actions">
                                <a href="#delete-modal" class="btn-action delete text-decoration-none" data-id="@genre.GenreId" onclick="prepareDelete(this)">Delete</a>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <div id="delete-modal" class="filmioo-modal-overlay">
        <div class="filmioo-modal-content">
            <i class="fa-solid fa-circle-exclamation warning-icon"></i>
            <h3>Are you sure?</h3>
            <p>Do you really want to delete ?</p>

            <div class="modal-actions">
                <a href="#" class="btn-cancel">Cancel</a>

                <form id="deleteForm" asp-action="Delete" asp-controller="Genre" method="post" style="display:inline;">
                    <input type="hidden" name="id" id="deleteGenreId" value="" />

                    <button type="submit" class="btn-confirm" style="border:none; cursor:pointer;">
                        Yes, Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
    <footer>
        &copy; 2026 Filmioo &mdash; Movies made better
    </footer>
</body>
</html>
<script>
    function prepareDelete(button) {
        var genreId = button.getAttribute('data-id');
        document.getElementById('deleteGenreId').value = genreId;
    }
</script>
