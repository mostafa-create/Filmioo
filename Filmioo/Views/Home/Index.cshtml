@model HomeViewModel

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Home Page</title>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
	<style>
		:root {
			--filmioo-black: #121212;
			--filmioo-purple-main: #9333ea;
			--filmioo-purple-light: #c084fc;
			--filmioo-text-color: #f0f0f0;
		}

		body {
			background-color: var(--filmioo-black);
			color: var(--filmioo-text-color);
			min-height: 100vh;
		}

		.filmioo-navbar {
			background-color: rgba(0, 0, 0, 0.9);
			border-bottom: 3px solid var(--filmioo-purple-main);
		}

		.filmioo-logo {
			color: var(--filmioo-purple-main) !important;
			font-size: 1.6rem;
			font-weight: 700;
			text-shadow: 0 0 8px var(--filmioo-purple-light);
		}

		.filmioo-nav-link {
			display: flex;
			align-items: center;
			color: var(--filmioo-text-color) !important;
			font-size: 0.9rem !important;
			font-weight: 400;
			letter-spacing: 0.3px;
			padding: 0.5rem 0.75rem !important;
			transition: all 0.25s ease-in-out;
			opacity: 0.85;
		}

			.filmioo-nav-link i {
				font-size: 1rem; 
				margin-right: 6px; 
				color: var(--filmioo-purple-light); 
			}


			.filmioo-nav-link:hover {
				color: #fff !important;
				opacity: 1;
				transform: translateY(-1px);
				text-shadow: 0 0 10px rgba(187, 134, 252, 0.4);
			}

		.nav-auth-link {
			font-weight: 500;
			opacity: 0.95;
		}


		.filmioo-hero-section {
			background: linear-gradient(135deg, #121212, #3a085b, #121212);
			background-size: 400% 400%;
			animation: gradientMove 10s ease infinite;
			border-radius: 0 0 20px 20px;
		}

		@@keyframes gradientMove {
			0% {
				background-position: 0% 50%;
			}

			50% {
				background-position: 100% 50%;
			}

			100% {
				background-position: 0% 50%;
			}
		}

		.movie-page-wrapper {
			padding: 20px 0;
		}

		.movie-section {
			margin-bottom: 40px;
		}

		.section-title {
			font-size: 1.6rem;
			font-weight: 700;
			color: var(--filmioo-text-color);
			text-shadow: 0 0 10px rgba(147, 51, 234, 0.3); 
			margin-bottom: 15px;
			letter-spacing: 0.5px;
		}

		.slider-container {
			position: relative;
			width: 100%;
		}

		.slider {
			display: flex;
			overflow-x: auto;
			overflow-y: hidden;
			padding: 20px 5%;
			gap: 20px;
			scroll-behavior: smooth;
			scrollbar-width: none; 
		}

			.slider::-webkit-scrollbar {
				display: none;
			}

		.movie-card {
			min-width: 190px;
			max-width: 190px;
			height: 285px;
			position: relative;
			border-radius: 12px;
			overflow: hidden;
			background-color: #1a1a1a;
			border: 1px solid rgba(147, 51, 234, 0.1); 
			transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
			cursor: pointer;
			box-shadow: 0 4px 15px rgba(0, 0, 0, 0.6);
		}

			.movie-card img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: filter 0.3s ease;
			}

			.movie-card:hover {
				transform: scale(1.1) translateY(-10px);
				z-index: 50;
				border-color: var(--filmioo-purple-light);
				box-shadow: 0 0 20px rgba(147, 51, 234, 0.5);
			}

				.movie-card:hover img {
					filter: brightness(0.7);
				}

		.card-overlay {
			position: absolute;
			inset: 0;
			background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(147, 51, 234, 0.2) 100%);
			display: flex;
			flex-direction: column;
			justify-content: flex-end;
			padding: 15px;
			opacity: 0;
			transition: opacity 0.3s ease;
		}

		.movie-card:hover .card-overlay {
			opacity: 1;
		}

		.movie-title {
			font-size: 1rem;
			font-weight: 600;
			color: var(--filmioo-text-color);
			margin-bottom: 5px;
			line-height: 1.2;
		}

		.movie-badge {
			position: absolute;
			top: 10px;
			right: 10px;
			background-color: var(--filmioo-purple-main);
			color: white;
			font-size: 0.75rem;
			padding: 2px 8px;
			border-radius: 4px;
			font-weight: bold;
			box-shadow: 0 0 5px var(--filmioo-purple-light);
		}


		.trailer-section {
			padding: 50px 0 40px;
		}

		.trailer-title {
			display: flex;
			align-items: center;
			gap: 14px;
			margin-bottom: 28px;
		}

			.trailer-title h2 {
				font-size: 1.8rem;
				font-weight: 700;
				color: var(--filmioo-text-color);
				margin: 0;
				letter-spacing: 0.5px;
			}

			.trailer-title .accent {
				width: 5px;
				height: 30px;
				border-radius: 6px;
				background: linear-gradient( 180deg, var(--filmioo-purple-light), var(--filmioo-purple-main) );
				box-shadow: 0 0 10px var(--filmioo-purple-main);
			}

		.trailer-card {
			width: 100%;
			border-radius: 20px;
			overflow: hidden;
			background: #000;
			border: 1px solid rgba(147, 51, 234, 0.15);
			box-shadow: 0 15px 40px rgba(0, 0, 0, 0.7), 0 0 20px rgba(147, 51, 234, 0.15);
			transition: all 0.3s ease;
		}

			.trailer-card:hover {
				transform: translateY(-4px);
				box-shadow: 0 20px 50px rgba(0, 0, 0, 0.8), 0 0 30px rgba(147, 51, 234, 0.35);
			}

			.trailer-card iframe {
				width: 100%;
				aspect-ratio: 16 / 9;
				display: block;
			}
		.search-container {
			max-width: 800px;
			margin: 0 auto;
			padding: 20px;
		}

		.search-wrapper {
			position: relative;
			display: flex;
			align-items: center;
			background: rgba(255, 255, 255, 0.05); 
			border: 1px solid rgba(138, 43, 226, 0.3); 
			border-radius: 50px;
			padding: 5px 10px;
			transition: all 0.3s ease;
			box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
		}

			.search-wrapper:focus-within {
				border-color: #8a2be2;
				box-shadow: 0 0 15px rgba(138, 43, 226, 0.4);
				background: rgba(255, 255, 255, 0.08);
			}

		.search-icon {
			color: #a29bfe;
			margin-left: 15px;
			font-size: 1.1rem;
		}

		.search-input {
			background: transparent;
			border: none;
			color: white;
			padding: 12px 15px;
			width: 100%;
			outline: none;
			font-size: 1rem;
		}

			.search-input::placeholder {
				color: rgba(255, 255, 255, 0.5);
			}

		.search-button {
			background: linear-gradient(45deg, #6c5ce7, #8a2be2);
			border: none;
			color: white;
			padding: 10px 25px;
			border-radius: 40px;
			cursor: pointer;
			font-weight: 600;
			transition: transform 0.2s ease, box-shadow 0.2s ease;
		}

			.search-button:hover {
				transform: scale(1.03);
				box-shadow: 0 0 10px rgba(138, 43, 226, 0.6);
			}

		.search-wrapper {
			position: relative;
		}

		.search-dropdown {
			position: absolute;
			top: 110%; 
			left: 0;
			right: 0;
			background: #1a1a1a;
			border: 1px solid rgba(138, 43, 226, 0.5);
			border-radius: 15px;
			z-index: 1000;
			overflow: hidden;
			box-shadow: 0 10px 30px rgba(0,0,0,0.8);
		}

		.search-result-item {
			padding: 12px 20px;
			color: white;
			cursor: pointer;
			display: flex;
			justify-content: space-between;
			transition: background 0.2s;
		}

			.search-result-item:hover {
				background: rgba(138, 43, 226, 0.2);
			}

		.result-year {
			color: #8a2be2;
			font-size: 0.85rem;
		}

	</style>
</head>

<body>
	<nav class="navbar navbar-expand-lg filmioo-navbar sticky-top">
		<div class="container-fluid">
			<a class="navbar-brand filmioo-logo" asp-action="Index" asp-controller="Home">Filmioo</a>

			<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
				<span class="navbar-toggler-icon"></span>
			</button>

			<div class="collapse navbar-collapse" id="navbarNav">
				<ul class="navbar-nav me-auto">
					<li class="nav-item">
						<a class="nav-link filmioo-nav-link" asp-action="Movies" asp-controller="Movie">
							<i class="bi bi-film me-1"></i> <span>Movies</span>
						</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link filmioo-nav-link" asp-action="Genres" asp-controller="Genre">
                            <i class="bi bi-grid-3x3-gap"></i> <span>Genres</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link filmioo-nav-link" asp-action="Index" asp-controller="Actor">
                            <i class="bi bi-people"></i> <span>Actors</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link filmioo-nav-link" asp-action="MyWatchList" asp-controller="WatchList">
							<i class="bi bi-bookmark-star"></i> <span>Watch List</span>
						</a>
					</li>

				</ul>

				<ul class="navbar-nav filmioo-icon-nav">
					@if (User.Identity.IsAuthenticated)
					{
						<li class="nav-item">
							<a class="nav-link filmioo-nav-link nav-auth-link" asp-action="Profile" asp-controller="Account" title="Profile">
								<i class="bi bi-person-circle filmioo-icon"></i><span>Profile</span>
							</a>
						</li>
						<li class="nav-item">
							<a class="nav-link filmioo-nav-link nav-auth-link" asp-action="SignOut" asp-controller="Account" title="Sign Out">
								<i class="bi bi-box-arrow-right filmioo-icon"></i><span>Sign Out</span>
							</a>
						</li>
					}
					else
					{
						<li class="nav-item">
							<a class="nav-link filmioo-nav-link nav-auth-link" asp-action="Login" asp-controller="Account">
								<i class="bi bi-box-arrow-in-right"></i> <span>Login</span>
							</a>
						</li>
						<li class="nav-item">
							<a class="nav-link filmioo-nav-link nav-auth-link" asp-action="Register" asp-controller="Account">
								<i class="bi bi-person-plus"></i> <span>Register</span>
							</a>
						</li>
					}
				</ul>

			</div>
		</div>
	</nav>

	<header class="container-fluid filmioo-hero-section py-5 mb-5 text-center">
		<h1 class="display-4">Discover, Review, Rate.</h1>
		<p class="lead">Your source for the latest movies and community ratings.</p>
	</header>

	<div class="search-container mb-5">
		<form asp-action="Index" method="get" class="search-form" id="movieSearchForm">
			<div class="search-wrapper">
				<i class="fas fa-search search-icon"></i>
				<input type="text" id="movieSearchInput" name="searchString" class="search-input" placeholder="Search for a movie..." autocomplete="off" />
				<button type="submit" class="search-button">Search</button>

				<div id="searchResultsDropdown" class="search-dropdown" style="display: none;">
				</div>
			</div>
		</form>
	</div>

	<section class="trailer-section">
		<div class="container">

			<div class="trailer-title">
				<span class="accent"></span>
				<h2>Featured Trailer</h2>
			</div>

			<div class="trailer-card">
				<iframe src="https://www.youtube.com/embed/cpsfNCZVexQ?autoplay=1&mute=1&loop=1&playlist=cpsfNCZVexQ&controls=0&modestbranding=1&rel=0"
						allow="autoplay; fullscreen"
						allowfullscreen>
				</iframe>
			</div>

		</div>
	</section>





	<div class="movie-page-wrapper">

		<section class="movie-section">
			<div class="trailer-title">
				<span class="accent"></span>
				<h2>Trending Now</h2>
			</div>
			<div class="slider-container">
				<div class="slider">
					@foreach (var movie in Model.Trending)
					{
						<div class="movie-card position-relative overflow-hidden">

							<a asp-action="Details" asp-controller="Movie" asp-route-id="@movie.Id" class="stretched-link"></a>

							<img src="@movie.Image_Name" alt="@movie.Title" onerror="this.src='/images/placeholder.jpg';">

							<div class="card-overlay">
								<span class="movie-title">@movie.Title</span>
							</div>
						</div>
					}
				</div>
			</div>
		</section>

		<section class="movie-section">
			<div class="trailer-title">
				<span class="accent"></span>
				<h2>Recently Added</h2>
			</div>
			<div class="slider-container">
				<div class="slider">
					@foreach (var movie in Model.RecentlyAdded)
					{
						<div class="movie-card position-relative overflow-hidden">
							<a asp-action="Details" asp-controller="Movie" asp-route-id="@movie.Id" class="stretched-link"></a>

							<img src="@movie.Image_Name" alt="@movie.Title">
							<div class="card-overlay">
								<span class="movie-title">@movie.Title</span>
							</div>
						</div>
					}
				</div>
			</div>
		</section>

		<section class="movie-section">
			<div class="trailer-title">
				<span class="accent"></span>
				<h2>Top Rated</h2>
			</div>
			<div class="slider-container">
				<div class="slider">
					@foreach (var movie in Model.TopRated)
					{
						<div class="movie-card position-relative overflow-hidden">
							<a asp-action="Details" asp-controller="Movie" asp-route-id="@movie.Id" class="stretched-link"></a>

							<img src="@movie.Image_Name" alt="@movie.Title">
							<div class="card-overlay">
								<span class="movie-title">@movie.Title</span>
							</div>
						</div>
					}
				</div>
			</div>
		</section>

	</div>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
<script>
	document.getElementById('movieSearchInput').addEventListener('input', async function (e) {
		const term = e.target.value;
		const dropdown = document.getElementById('searchResultsDropdown');

		if (term.length < 2) {
			dropdown.style.display = 'none';
			return;
		}

		const response = await fetch(`/Movie/GetSearchSuggestions?term=${term}`);
		const movies = await response.json();

		if (movies.length > 0) {
			dropdown.innerHTML = movies.map(m => `
					<div class="search-result-item" onclick="window.location.href='/Movie/Details/${m.id}'">
						<span>${m.title}</span>
						<span class="result-year">${m.year ?? ''}</span>
					</div>
				`).join('');
			dropdown.style.display = 'block';
		} else {
			dropdown.style.display = 'none';
		}
	});

	document.addEventListener('click', (e) => {
		if (!document.getElementById('movieSearchForm').contains(e.target)) {
			document.getElementById('searchResultsDropdown').style.display = 'none';
		}
	});
</script>

